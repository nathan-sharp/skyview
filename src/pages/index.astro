---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION, CONTENT_CREATOR_HANDLE } from '../consts';
import { getAuthorVideos } from '../lib/atproto';

const videos = await getAuthorVideos(CONTENT_CREATOR_HANDLE);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* --- Sidebar Logic --- */
			
			/* Base State (Mini Sidebar) */
			/* This applies to mobile, or when explicitly closed on desktop */
			aside {
				width: 72px;
				height: calc(100vh - var(--header-height));
				position: fixed;
				left: 0;
				top: var(--header-height);
				background: var(--primary);
				overflow-y: auto;
				padding: 4px 0;
				transition: width 0.2s; /* Smooth animation */
			}

			main { 
				margin-left: 72px; 
				padding: 24px;
				width: 100%;
				transition: margin-left 0.2s;
			}

			.nav-item {
				display: flex;
				flex-direction: column;
				align-items: center;
				padding: 16px 0;
				cursor: pointer;
				border-radius: 10px;
				color: white;
				justify-content: center;
				margin: 0 4px;
			}
			.nav-item:hover {
				background-color: var(--secondary);
			}
			
			.nav-item svg {
				margin-bottom: 6px;
				width: 24px;
				height: 24px;
			}
			
			.nav-item span {
				font-size: 10px;
				text-overflow: ellipsis;
				white-space: nowrap;
				overflow: hidden;
				max-width: 100%;
			}

			/* Expanded State (Desktop Default) */
			/* Applies only on large screens AND when 'sidebar-closed' is NOT on body */
			@media (min-width: 1200px) {
				body:not(.sidebar-closed) aside {
					width: var(--sidebar-width);
					padding: 12px;
				}
				
				body:not(.sidebar-closed) main {
					margin-left: var(--sidebar-width);
				}

				body:not(.sidebar-closed) .nav-item {
					flex-direction: row;
					padding: 0 12px;
					height: 40px;
					margin-bottom: 4px;
					justify-content: flex-start;
				}

				body:not(.sidebar-closed) .nav-item svg {
					margin-bottom: 0;
					margin-right: 24px;
				}

				body:not(.sidebar-closed) .nav-item span {
					font-size: 14px;
				}
			}

			.nav-item.active {
				background-color: var(--secondary);
				font-weight: 500;
			}


			/* --- Video Grid --- */
			.video-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 16px;
				row-gap: 40px;
			}

			.video-card {
				cursor: pointer;
			}

			.thumbnail-container {
				position: relative;
				width: 100%;
				border-radius: 12px;
				overflow: hidden;
				aspect-ratio: 16/9;
				background: #000;
			}

			video {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.video-meta {
				display: flex;
				margin-top: 12px;
				gap: 12px;
			}

			.avatar {
				width: 36px;
				height: 36px;
				border-radius: 50%;
				background: #333;
			}

			.details {
				flex: 1;
			}

			.title {
				font-size: 16px;
				font-weight: 600;
				line-height: 1.4;
				margin: 0 0 4px 0;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.channel-name, .meta-text {
				font-size: 14px;
				color: var(--text-gray);
				margin: 0;
				line-height: 1.3;
			}
			
			.channel-name:hover {
				color: white;
			}

			.no-videos {
				text-align: center;
				grid-column: 1 / -1;
				padding: 4rem;
				color: var(--text-gray);
			}
		</style>
	</head>
	<body>
		<Header />
		
		<div class="app-layout">
			<aside>
				<a href="/" class="nav-item active">
					<svg viewBox="0 0 24 24" focusable="false"><path d="M4 21V10.08l8-6.96 8 6.96V21h-6v-6h-4v6H4z" fill="currentColor"></path></svg>
					<span>Home</span>
				</a>
				
				<a href="#" class="nav-item">
					<svg viewBox="0 0 24 24" focusable="false"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-5.5-2.5 7.51-3.49L17.5 6.5 9.99 9.99 6.5 17.5zm5.5-6.6c.61 0 1.1.49 1.1 1.1s-.49 1.1-1.1 1.1-1.1-.49-1.1-1.1.49-1.1 1.1-1.1z" fill="currentColor"></path></svg>
					<span>Discover</span>
				</a>

				<a href="#" class="nav-item">
					<svg viewBox="0 0 24 24" focusable="false"><path d="M10.59 4.59C10.21 4.21 9.7 4 9.17 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-3.59z" fill="currentColor"></path></svg>
					<span>Following</span>
				</a>

				<a href="#" class="nav-item">
					<svg viewBox="0 0 24 24" focusable="false"><path d="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2zm0 15l-5-2.18L7 18V5h10v13z" fill="currentColor"></path></svg>
					<span>Saved</span>
				</a>

				<a href="#" class="nav-item">
					<svg viewBox="0 0 24 24" focusable="false"><path d="M11.97 3.01c-4.96.01-8.98 4.02-8.97 8.98.01 4.96 4.02 8.98 8.98 8.97 4.96-.01 8.98-4.02 8.97-8.98-.01-4.96-4.02-8.98-8.98-8.97zm0 1.5c4.13-.01 7.48 3.33 7.47 7.47-.01 4.13-3.33 7.48-7.47 7.47-4.13.01-7.48-3.33-7.47-7.47.01-4.13 3.33-7.48 7.47-7.47zM11 7v5.41l4.29 2.58.75-1.23-3.54-2.13V7h-1.5z" fill="currentColor"></path></svg>
					<span>History</span>
				</a>

				<a href="#" class="nav-item">
					<svg viewBox="0 0 24 24" focusable="false"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" fill="currentColor"></path></svg>
					<span>Profile</span>
				</a>
			</aside>

			<main>
				{videos.length === 0 ? (
					<div class="no-videos">
						<p>No videos found for @{CONTENT_CREATOR_HANDLE}.</p>
					</div>
				) : (
					<div class="video-grid">
						{videos.map((video) => (
							<div class="video-card">
								<div class="thumbnail-container">
									<video
										poster={video.thumbnail}
										data-hls-src={video.playlist}
										muted
										onmouseover="this.play()"
										onmouseout="this.pause();this.currentTime=0;"
										crossorigin="anonymous"
										playsinline
									></video>
								</div>
								<div class="video-meta">
									<img src={video.author.avatar} class="avatar" alt="" />
									<div class="details">
										<h3 class="title">{video.text || "Untitled Video"}</h3>
										<p class="channel-name">{video.author.displayName}</p>
										<p class="meta-text">
											{Math.floor(Math.random() * 900) + 10}K views • {new Date(video.createdAt).toLocaleDateString()}
										</p>
									</div>
								</div>
							</div>
						))}
					</div>
				)}
			</main>
		</div>

		<script>
			import Hls from 'hls.js';

			document.addEventListener('DOMContentLoaded', () => {
				const videos = document.querySelectorAll('video[data-hls-src]');

				videos.forEach((video: any) => {
					const src = video.getAttribute('data-hls-src');
					if (!src) return;

					if (Hls.isSupported()) {
						const hls = new Hls();
						hls.loadSource(src);
						hls.attachMedia(video);
					} else if (video.canPlayType('application/vnd.apple.mpegurl')) {
						video.src = src;
					}
				});
			});
		</script>
	</body>
</html>