---
import { SITE_TITLE } from '../consts';
---

<header>
	<div class="start">
		<button class="btn-icon menu-btn" aria-label="Toggle Menu">
			<svg height="24" viewBox="0 0 24 24" width="24" focusable="false" style="pointer-events: none; display: block; width: 100%; height: 100%;"><path d="M21 6H3V5h18v1zm0 5H3v1h18v-1zm0 6H3v1h18v-1z" fill="white"></path></svg>
		</button>
		<a href="/" class="logo">
			<span class="logo-icon">☁️</span>
			<span class="logo-text">{SITE_TITLE}</span>
		</a>
	</div>

	<div class="center">
		<form class="search-form" onsubmit="event.preventDefault();">
			<div class="search-input-wrapper">
				<input type="text" placeholder="Search" />
			</div>
			<button class="search-btn">
				<svg height="24" viewBox="0 0 24 24" width="24" focusable="false"><path d="M20.87 20.17l-5.59-5.59C16.35 13.35 17 11.75 17 10c0-3.87-3.13-7-7-7s-7 3.13-7 7 3.13 7 7 7c1.75 0 3.35-.65 4.58-1.28l5.59 5.59 1.7-1.7zM10 16c-3.31 0-6-2.69-6-6s2.69-6 6-6 6 2.69 6 6-2.69 6-6 6z" fill="currentColor"></path></svg>
			</button>
		</form>
		<button class="btn-icon mic-btn">
			<svg height="24" viewBox="0 0 24 24" width="24" focusable="false"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z" fill="currentColor"></path><path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z" fill="currentColor"></path></svg>
		</button>
	</div>

	<div class="end">
		<button class="btn-icon">
			<svg height="24" viewBox="0 0 24 24" width="24" focusable="false"><path d="M14 13h-3v3H9v-3H6v-2h3V8h2v3h3v2zM17 6H3v12h14v-6.39l4 1.83V8.56l-4 1.83V6m1-1v3.83L22 7v8l-4-1.83V19H2V5h16z" fill="currentColor"></path></svg>
		</button>
		<button class="btn-icon">
			<svg height="24" viewBox="0 0 24 24" width="24" focusable="false"><path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.64 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2zm-2 1H8v-6c0-2.48 1.51-4.5 4-4.5s4 2.02 4 4.5v6z" fill="currentColor"></path></svg>
		</button>
		<button class="btn-icon profile-btn">
			<span>N</span>
		</button>
	</div>
</header>

<script>
	const menuBtn = document.querySelector('.menu-btn');
	if (menuBtn) {
		menuBtn.addEventListener('click', () => {
			document.body.classList.toggle('sidebar-closed');
		});
	}
</script>

<style>
	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		height: var(--header-height);
		background: var(--primary);
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 16px;
		z-index: 100;
	}

	.start {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 4px;
		font-size: 1.2rem;
		font-weight: bold;
		letter-spacing: -0.5px;
	}

	.center {
		display: flex;
		align-items: center;
		flex: 1;
		max-width: 720px;
		margin: 0 40px;
		gap: 8px;
	}

	.search-form {
		display: flex;
		flex: 1;
		height: 40px;
	}

	.search-input-wrapper {
		flex: 1;
		background: #121212;
		border: 1px solid #303030;
		border-right: none;
		border-radius: 40px 0 0 40px;
		padding: 0 16px;
		display: flex;
		align-items: center;
		margin-left: 32px;
	}
	
	.search-input-wrapper:focus-within {
		border-color: #1c62b9;
	}

	input {
		width: 100%;
		background: transparent;
		border: none;
		color: white;
		font-size: 16px;
		outline: none;
	}

	.search-btn {
		width: 64px;
		background: #222;
		border: 1px solid #303030;
		border-radius: 0 40px 40px 0;
		cursor: pointer;
		color: white;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.search-btn:hover {
		background: #303030;
	}

	.mic-btn {
		background: #181818;
		width: 40px;
		height: 40px;
	}

	.end {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.profile-btn {
		background: #5c6bc0;
		width: 32px;
		height: 32px;
		font-size: 14px;
		margin-left: 8px;
	}
</style>